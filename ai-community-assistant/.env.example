# Environment Configuration
# Copy this file to .env and fill in your values

# Required: Discord Bot Token
# Get this from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Required: Discord Application Client ID
CLIENT_ID=your_client_id_here

# Optional: Test Server ID (for development)
GUILD_ID=your_test_server_id_here

# Required: OpenAI API Key
# Get this from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: OpenAI Model (defaults to gpt-4)
OPENAI_MODEL=gpt-4

# Optional: Bot Activity Status
BOT_ACTIVITY=Helping the community

# Optional: Database Path (defaults to ./data/bot.db)
DATABASE_PATH=./data/bot.db

# Optional: Log Level (debug, info, warn, error)
LOG_LEVEL=info

# Optional: AI Response Temperature (0.0 - 1.0)
# Lower = more focused, Higher = more creative
AI_TEMPERATURE=0.7

# Optional: Max AI Response Length
MAX_RESPONSE_LENGTH=2000

# Optional: Welcome Channel ID
WELCOME_CHANNEL_ID=

# Optional: Moderation Log Channel ID
MOD_LOG_CHANNEL_ID=

# Optional: Knowledge Base Admin Role ID
KNOWLEDGE_ADMIN_ROLE_ID=
