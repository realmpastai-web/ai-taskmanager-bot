FROM node:18-alpine

WORKDIR /app

# Install dependencies for better-sqlite3
RUN apk add --no-cache python3 make g++

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm ci --only=production

# Copy source code
COPY src ./src

# Create data directory
RUN mkdir -p data

# Expose port for health checks
EXPOSE 3000

# Start the bot
CMD ["node", "src/index.js"]
