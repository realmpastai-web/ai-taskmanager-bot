# Environment Configuration

# Discord Bot Token (REQUIRED)
# Get from: https://discord.com/developers/applications → Your App → Bot → Token
DISCORD_TOKEN=your_bot_token_here

# Welcome Channel ID (REQUIRED)
# Right-click channel → Copy Channel ID (enable Developer Mode in Discord settings)
WELCOME_CHANNEL_ID=1234567890123456789

# Auto-Role ID (OPTIONAL)
# Role automatically assigned to new members
# Bot's role MUST be higher than this role in server settings!
AUTO_ROLE_ID=

# DM Welcome Settings
ENABLE_DM_WELCOME=true
SERVER_NAME=Your Awesome Server

# Custom Welcome Message (use {user} and {server} placeholders)
# If not set, uses default message
CUSTOM_WELCOME_MESSAGE=Hey {user}! Welcome to {server}! 🎉

# Optional: Bot status message
BOT_STATUS=Watching over new members