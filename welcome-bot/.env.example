# Environment Configuration
NODE_ENV=production

# Discord Bot Token (REQUIRED)
# Get this from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Discord Application ID (REQUIRED)
# Found in your Discord application page
CLIENT_ID=your_client_id_here

# Welcome Channel ID (REQUIRED)
# Right-click channel → Copy Channel ID (enable Developer Mode first)
WELCOME_CHANNEL_ID=your_channel_id_here

# Optional: Log Channel ID for join/leave logs
LOG_CHANNEL_ID=your_log_channel_id_here

# Optional: Role to auto-assign to new members
# Leave empty to disable auto-role
AUTO_ROLE_ID=your_role_id_here

# Optional: DM new members with server info
# Set to "true" to enable
ENABLE_DM_WELCOME=false

# Welcome Message Customization
# Use {user} for mention, {username} for name, {server} for server name, {count} for member count
WELCOME_MESSAGE=🎉 Welcome {user} to **{server}**! You are our **{count}th** member!
LEAVE_MESSAGE=👋 {username} has left the server.

# Bot Status Message
STATUS_MESSAGE=over new members